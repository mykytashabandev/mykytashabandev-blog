---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { BLOG_TAGS, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getReadingTime } from '../../utils/readingTime';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsWithMeta = posts.map((post) => ({
	...post,
	readingTime: getReadingTime(post.body ?? ''),
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<div class="page-header">
				<h1>Articles</h1>
				<p class="page-sub">All writing on web performance, in reverse chronological order.</p>
			</div>

			<div class="tag-filter">
				<a href="/blog" class="tag-chip active">All</a>
				{BLOG_TAGS.map((tag) => (
					<a href={`/blog/tag/${tag}/`} class="tag-chip">#{tag}</a>
				))}
			</div>

			<ul class="post-list">
				{postsWithMeta.map((post) => (
					<li class="post-item">
						<a href={`/blog/${post.id}/`} class="post-link">
							<div class="post-body">
								<span class="post-title">{post.data.title}</span>
								{post.data.description && (
									<span class="post-desc">{post.data.description}</span>
								)}
								{post.data.tags?.length > 0 && (
									<div class="post-tags">
										{post.data.tags.map((tag) => (
											<span class="tag">#{tag}</span>
										))}
									</div>
								)}
							</div>
							<div class="post-right">
								<FormattedDate date={post.data.pubDate} />
								<span class="reading-time">{post.readingTime} min</span>
							</div>
						</a>
					</li>
				))}
			</ul>

		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		padding-bottom: var(--space-xl);
		border-bottom: 1px solid var(--border);
		margin-bottom: var(--space-lg);
	}

	.page-header h1 {
		font-size: 1.5rem;
		margin-bottom: var(--space-sm);
	}

	.page-sub {
		font-size: 0.875rem;
		color: var(--text-muted);
		margin: 0;
	}

	.tag-filter {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin-bottom: var(--space-xl);
	}

	.tag-chip {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-muted);
		text-decoration: none;
		padding: 0.25em 0.6em;
		border: 1px solid var(--border-hover);
		border-radius: 4px;
		transition: color var(--transition), border-color var(--transition);
	}

	.tag-chip:hover,
	.tag-chip.active {
		color: var(--text);
		border-color: var(--text-muted);
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.post-item {
		border-top: 1px solid var(--border);
	}

	.post-item:last-child {
		border-bottom: 1px solid var(--border);
	}

	.post-link {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-xl);
		padding: var(--space-lg) 0;
		text-decoration: none;
	}

	.post-link:hover .post-title {
		color: var(--accent);
	}

	.post-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		flex: 1;
		min-width: 0;
	}

	.post-title {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--text);
		transition: color var(--transition);
	}

	.post-desc {
		font-size: 0.825rem;
		color: var(--text-muted);
		line-height: 1.5;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.1rem;
	}

	.tag {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: var(--text-subtle);
	}

	.post-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.25rem;
		flex-shrink: 0;
		padding-top: 0.1em;
	}

	.reading-time {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-subtle);
	}

	@media (max-width: 540px) {
		.post-link {
			flex-direction: column;
			gap: var(--space-sm);
		}

		.post-right {
			flex-direction: row;
			align-items: center;
			gap: var(--space-md);
		}
	}
</style>
