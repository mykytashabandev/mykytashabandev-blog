---
interface Props {
	date: Date;
}

const { date } = Astro.props;
---

<time class="formatted-date" datetime={date.toISOString()}>
	{
		date.toLocaleDateString('en-us', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>

<style>
	.formatted-date {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-muted);
		letter-spacing: 0.02em;
	}
</style>
